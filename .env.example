# ── Database ──────────────────────────────────────────────────────────
# DATABASE_PATH=data/pfm.db

# ── OKX (read-only API key) ──────────────────────────────────────────
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# ── Binance Global (read-only API key) ───────────────────────────────
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ── Binance TH (read-only API key) ──────────────────────────────────
# BINANCE_TH_API_KEY=
# BINANCE_TH_API_SECRET=

# ── Bybit (read-only API key) ───────────────────────────────────────
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# ── Stellar / Lobstr / Blend ────────────────────────────────────────
# STELLAR_PUBLIC_ADDRESS=G...
# BLEND_POOL_CONTRACT_ID=
# SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.gateway.fm

# ── Wise (Personal Token) ───────────────────────────────────────────
# WISE_API_TOKEN=

# ── IBKR (Flex Query) ───────────────────────────────────────────────
# IBKR_FLEX_TOKEN=
# IBKR_FLEX_QUERY_ID=

# ── Telegram (push-only bot) ────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Claude API (AI commentary) ──────────────────────────────────────
# ANTHROPIC_API_KEY=

# ── CoinGecko (optional, free tier works without) ───────────────────
# COINGECKO_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── KBank (Gmail IMAP for auto-fetching PDF statements) ──────────
# GMAIL_ADDRESS=your@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# KBANK_SENDER_EMAIL=K-ElectronicDocument@kasikornbank.com
# KBANK_PDF_PASSWORD=DDMMYYYY  # your date of birth
